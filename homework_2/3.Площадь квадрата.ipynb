    "import math\n",
    "\n",
    "def square(side_square):\n",
    "    return math.ceil(side_square * side_square)\n",
    "\n",
    "side = float(input('Введите длину стороны квадрата: '))\n",
    "area = square(side)\n",
    "print(f'Площадь квадрата: {area}')\n"
